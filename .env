# ============================================================
# YS | 94 Bot — Environment Variables
# Fill in ALL values before running the bot.
# ============================================================

# Telegram bot token — get it from @BotFather
BOT_TOKEN=

# Numeric ID of the private admin channel (-100xxxxxxxxxx)
ADMIN_CHANNEL_ID=

# Your personal Telegram user ID (full owner control)
# Find your ID by messaging @userinfobot
OWNER_ID=

# Comma-separated Telegram user IDs of additional admins
# OWNER_ID is always included automatically — no need to repeat it
# Example: ADMIN_IDS=111111111,222222222
ADMIN_IDS=

# Mandatory subscription channels (defaults are correct)
SUPPORT_CHANNEL=@shaheen_ys
GIFT_CHANNEL=@fi1_oo
